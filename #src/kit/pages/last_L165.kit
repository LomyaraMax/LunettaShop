<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <!-- @import '../link.html' -->


</head>
<body>
    
    <div class="wrapper">

        <!-- @import '../../../header.html' -->

        <main class="main">
            <div class="container">
                <div class="item">
                    <div class="slider">
                        <div class="main-image">
                            <img id="mainPhoto" src="../../../images/img/L165.webp" alt="Main Image">
                        </div>
                        <div class="thumbnails">
                            <img src="../../../images/img/L165.webp" alt="Thumb 1" class="thumb active">
                            <img src="../../../images/img/L165_2.webp" alt="Thumb 1" class="thumb active">
                            <img src="../../../images/img/L165_3.webp" alt="Thumb 2" class="thumb">
                            <img src="../../../images/img/L165_4.webp" alt="Thumb 3" class="thumb">
                            <img src="../../../images/img/L165_5.webp" alt="Thumb 4" class="thumb">
                            <img src="../../../images/img/L165_9.webp" alt="Thumb 7" class="thumb">
                            
                        </div>
                    </div>
                    <div class="text">
                        <div class="title">Louis Vuitton sunset 🔥<span>Арт.L165</span></div>
                        <div class="price">4699грн</div>
                        <div class="description">
                            <div class="fubtitle">Опис товару</div>
                            <div class="option">
                                <ul class="circle-list">
                                    <li>Розмір 24*15*7 см</li>
                                    <li>Матеріал : текстиль</li>
                                    <li>Один відділ + додаткова кишеня</li>
                                    <li>Ремінець короткий, і другий короткий ремінець - який чіпляється разом для крос боді</li>
                                    <li>Подвійна брендова коробка/брендовий пильовик</li>
                                </ul>
                            </div>
                        </div>
                        <div class="esc"><a href="../../../index.html"><button>На головну</button></a></div>
                    </div>
                </div>
            </div>
        </main>

    <!-- @import '../../../footer.html' -->

    </div>

    

    <script src="../../script/pagesScript.js"></script>
</body>
</html>